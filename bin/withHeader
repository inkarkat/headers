#!/bin/bash

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: cat FILE [...] | [HEADER_SINK=FILESPEC|&N] [HEADER_STYLE=dashed-line] [HEADER_WIDTH=N] [HEADER_ALWAYS_NEWLINE=1|t|true] %q %s\n' "$(basename "$1")" '[--first|--id ID] [--no-newline|--always-newline] [--color=(always|auto|never)|--no-color] [--] HEADER [...] [-?|-h|--help]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
If non-empty input is piped into this command, prepends HEADER before the
output. If there's no output, nothing is printed. Trailing empty lines at the
end of the input are omitted. An empty separator line is added before all
HEADERs (except the first one).
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --first		Do not add an empty separator line before this first
			header.
    --id ID		ID to uniquely identify invocations of this command
			(e.g. use PARENT-COMMAND-NAME-\$\$), so that the first
			one does not add an empty separator line.
    --no-newline	Directly append input after the header and indent
			additional indent lines by the header width. By default,
			input appears unindented on new lines.
    --always-newline	Always print the header on a separate line, even if the
			input consists only of a single line.
			By default, a single line of input is printed directly
			after the header.
HELPTEXT
}

# Duplicated to +/HEADER_STYLE header
case "$HEADER_STYLE" in
    dashed-line)
	: ${HEADER_PREFIX='-- '}
	: ${HEADER_SUFFIX=' ----------------------------------------------------------------------------'}
	: ${HEADER_COLON=''}
	: ${HEADER_WIDTH=80}
	;;
esac
: ${HEADER_COLOR='[1m'}
: ${HEADER_RESET='[0m'}
: ${HEADER_SEPARATOR=$'\n'}
: ${HEADER_INDENT=}
: ${HEADER_COLON=:}
: ${HEADER_NEWLINE=$'\n'}
: ${HEADER_TAB=$'\t'}
: ${HEADER_WIDTH=}
: ${HEADER_ID_INTERVAL:=1h}

typeset -a colorArg=()
isHeaderIndent=
isAlwaysNewline=$HEADER_ALWAYS_NEWLINE
isIdChange() { return 1; }
clearId() { :; }
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--first)	shift; HEADER_SEPARATOR='';;
	--id)		shift; passedId="$1"; shift
			marker()
			{
			    executionMarker --base-type runtime --group withHeader "$@"
			}
			isIdChange()
			{
			    local isChange=t
			    marker --query "$passedId" --newer "$HEADER_ID_INTERVAL" && isChange=

			    # Omit separator on the first header associated with
			    # ID, and record the ID to be able to recognize it on
			    # subsequent calls.
			    marker --update "$passedId"

			    [ "$isChange" ]
			}
			clearId()
			{
			    marker --delete "$passedId"
			}
			;;
	--no-newline)	shift; HEADER_NEWLINE=' '; isHeaderIndent=t;;
	--always-newline)
			shift; isAlwaysNewline=t;;
	--no-color|--color=*)	colorArg=("$1"); shift;;
	--color)		colorArg=("$1" "$2"); shift; shift;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done
if [ $# -eq 0 ]; then
    printUsage "$0" >&2
    exit 2
fi

case "$HEADER_SINK" in
    '')		exec 3>&1;;
    \&[0-9])	eval "exec 3>$HEADER_SINK";;
    ?*)		exec 3>>"$HEADER_SINK";;
esac

header="${HEADER_PREFIX}${*}${HEADER_SUFFIX}"
if [ -n "$HEADER_WIDTH" ]; then
    printf -v header "%${HEADER_WIDTH}s" "$header"
    header="${header:0:${HEADER_WIDTH#-}}"
fi

if ! isNeedColorArgumentWhenPiping "${colorArg[@]}"; then
    HEADER_COLOR=''
    HEADER_RESET=''
fi

typeset -a furtherLineProcessingSedArgs=()
if [ "$isHeaderIndent" ]; then
    printf -v headerLikeIndent "%$((${#header} + ${#HEADER_COLON} + ${#HEADER_NEWLINE}))s" ' '
    furtherLineProcessingSedArgs=(-e "/./s/^/${headerLikeIndent}/")
fi

typeset -a buffer=()
printHeaderAndBuffer()
{
    isIdChange && HEADER_SEPARATOR=''
    printf >&3 %s "$HEADER_SEPARATOR" "$HEADER_INDENT" "$HEADER_COLOR" "$header" "$HEADER_RESET" "$HEADER_COLON" "$HEADER_NEWLINE"
    printf '%s\n' "${buffer[@]}"
    buffer=()
}

# Consume first line(s) until we have a non-blank one; then we know that we need
# a header first.
while IFS=$'\n' read -r line || [ -n "$line" ]
do
    buffer+=("$line")
    if [ -n "$line" ]; then
	if [ "$isAlwaysNewline" ] || [ ${#buffer[@]} -gt 1 ]; then
	    printHeaderAndBuffer
	    break
	fi
    fi
done
if [ ${#buffer[@]} -eq 1 ]; then
    # Print a single line of input directly after the header.
    HEADER_NEWLINE="$HEADER_TAB" printHeaderAndBuffer
    clearId # We don't need a separator line after an inline header with a single line of input.
elif [ ${#buffer[@]} -gt 1 ]; then
    printf >&2 'ASSERT: Expected 0 or 1 lines in buffer, but got %d.\n' ${#buffer[@]}; exit 3
fi

# Delete all trailing blank lines at the end of the input.
exec sed --unbuffered "${furtherLineProcessingSedArgs[@]}" -e :a -e '/^\n*$/{$d; N; ba' -e '}'
